# PostgreSQL Database Configuration
POSTGRES_USER=alex_user
POSTGRES_PASSWORD=alex_password
POSTGRES_DB=alex_db
POSTGRES_PORT=5433

# Redis Cache Configuration
REDIS_URL=redis://localhost:6379/0

# Backend API Configuration
DATABASE_URL=postgresql+asyncpg://alex_user:alex_password@localhost:5433/alex_db
GEMINI_API_KEY=your_google_gemini_api_key_here
GEMINI_MODEL=gemini-3.5-flash

# Security Secrets (Enterprise Role Separation)
JWT_SECRET=alex_jwt_secret_token_signing_key_32bytes
ENCRYPTION_KEY=alex_db_token_encryption_key_32bytes

# Frontend Public API URL
NEXT_PUBLIC_API_URL=http://localhost:8000
